set nocompatible


set path+=.

set path+=,,

set number
set relativenumber

set wrap

set showmode

set ruler

set laststatus =2

set report =0

set  listchars=nbsp:%,tab:▸\ ,trail:_,eol:¬,precedes:←,extends:→
set  tabstop=4 softtabstop=4 shiftwidth=4 expandtab

set wildmenu
set wildmode=full

set fileformat=unix
